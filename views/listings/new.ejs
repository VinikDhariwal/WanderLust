<% layout("/layouts/boilerplate") %>
<div class="container mt-4 mb-5" style="max-width: 600px;">
  <h3 class="mb-4">Create a New Listing</h3>
  <form method="POST" 
    action="/listings" 
    novalidate class="needs-validation" 
    enctype="multipart/form-data">

    <!-- Title -->
    <div class="mb-3">
      <label class="form-label">Title</label>
      <input 
        name="listing[title]" 
        type="text" 
        class="form-control"
        required
      />
      <div class="invalid-feedback">Enter a valid title for the place!</div>
    </div>

    <!-- Description -->
    <div class="mb-3">
      <label class="form-label">Description</label>
      <textarea 
        name="listing[description]" 
        class="form-control"
        rows="3"
        required
      ></textarea>
      <div class="invalid-feedback">A description is required!</div>
    </div>

    <!-- Image -->
    <div class="mb-3">
      <label class="form-label">Image</label>
      <input 
        name="listing[image]"  
        type="file"
        class="form-control"
      />
    </div>

    <!-- Category -->
    <div class="mb-3">
      <label class="form-label">Category</label>
      <select name="listing[category]" class="form-select">
        <option value="all">All</option>
        <option value="trending">Trending</option>
        <option value="beach">Beach</option>
        <option value="mountain">Mountains</option>
        <option value="city">City</option>
        <option value="countryside">Countryside</option>
        <option value="pool">Pools</option>
        <option value="cabin">Cabins</option>
        <option value="camping">Camping</option>
        <option value="luxury">Luxury</option>
        <option value="arctic">Arctic</option>
        <option value="desert">Desert</option>
        <option value="island">Islands</option>
        <option value="lake">Lake</option>
        <option value="farm">Farms</option>
      </select>
    </div>

    <!-- Price -->
    <div class="mb-3">
      <label class="form-label">Price</label>
      <input 
        name="listing[price]"  
        type="number" 
        class="form-control"
        required
      />
      <div class="invalid-feedback">Please enter a valid price!</div>
    </div>

    <!-- Location & Country -->
    <div class="row mb-4">
      <div class="col-6">
        <label class="form-label">Location</label>
        <input 
          name="listing[location]"  
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please enter a location!</div>
      </div>
      <div class="col-6">
        <label class="form-label">Country</label>
        <input 
          name="listing[country]"  
          type="text" 
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please enter country name!</div>
      </div>
    </div>

    <button class="btn btn-dark add-btn w-100">Add Listing</button>
  </form>
</div>
<% layout("/layouts/boilerplate") %>
<div class="heading mt-3 mr-0 mb-3">
  <h3>All Listings</h3>
</div>
<div class="listings mt-4 mb-5">
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4 justify-content-center">

    <% for (let listing of allListings) { %>

      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-links">
          <div class="card h-100">
            
            <img 
              src="<%= listing.image %>" 
              class="card-img-top" 
              alt="listing_image"
            >

            <div class="card-img-overlay"></div>

            <div class="card-body">
              <p class="card-text">
                <b><%= listing.title %></b>
              </p>
            </div>
            <div class="card-body">
              <p class="card-text">
                &#8377;<%= listing.price.toLocaleString("en-IN") %> / night
              </p>
            </div>

          </div>
        </a>
      </div>

    <% } %>

  </div>
</div>
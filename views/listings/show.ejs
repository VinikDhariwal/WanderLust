<% layout("/layouts/boilerplate")%>
<div class="row mt-3">
  <div class="col-8 offset-2">
  <h3>Listing Details :</h3>
  <div class="card">
    <img src="<%= listing.image %>>" class="card-img-top show-img" alt="listing_image" />
    <div class="card-body">
      <b><%= listing.title %></b>
      <%= listing.description %><br>
      &#8377;<%= listing.price?.toLocaleString("en-IN") || "0" %><br>
      <%= listing.location %><br>
      <%= listing.country %><br>
    </div>
  </div>
  <br />
<div class="row g-2  mb-4">
  <div class="col-6">
    <a href="/listings/<%= listing._id %>/edit" 
       class="btn btn-outline-dark edit-btn w-100">
       Edit
    </a>
  </div>

  <div class="col-6">
    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-outline-dark del-btn w-100">
        Delete
      </button> 
    </form>
  </div>
</div>
</div>
</div>
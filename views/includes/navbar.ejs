<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
  <div class="container">

    <!-- ================= BRAND / LOGO ================= -->
    <!-- Main application logo that redirects to listings page -->

    <a class="navbar-brand fw-semibold" href="/listings">
      <i class="fa-regular fa-compass me-2"></i>WanderLust
    </a>


    <!-- ================= MOBILE NAVBAR TOGGLER ================= -->
    <!-- Controls collapsing navigation for smaller screens -->

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
    >
      <span class="navbar-toggler-icon"></span>
    </button>


    <div class="collapse navbar-collapse" id="navbarNav">


      <!-- ================= CENTER NAVIGATION LINKS ================= -->
      <!-- Core navigation links for browsing listings -->

      <div class="navbar-nav mx-auto">

        <a class="nav-link fw-medium" href="/listings">
          Explore
        </a>

        <a class="nav-link fw-medium" href="/listings/new">
          Add Estate
        </a>

      </div>


      <!-- ================= PROFILE / AUTH MENU ================= -->
      <!-- Airbnb-style profile dropdown menu -->

      <div class="dropdown ms-auto">

        <!-- Profile Menu Button -->
        <!-- Contains hamburger icon and user avatar -->

        <button
          class="profile-menu-btn"
          data-bs-toggle="dropdown"
          aria-expanded="false"
        >

          <!-- Hamburger icon -->
          <i class="fa-solid fa-bars"></i>

          <!-- Show avatar only when user is logged in -->
          <% if(currUser){ %>

            <img
              src="https://i.pravatar.cc/40?u=<%= currUser.username %>"
              class="avatar"
              alt="profile"
            >

          <% } %>

        </button>


        <!-- ================= DROPDOWN MENU ================= -->
        <!-- Content of menu changes depending on authentication -->

        <ul class="dropdown-menu dropdown-menu-end shadow border-0">


          <!-- ========= USER NOT LOGGED IN ========= -->

          <% if(!currUser){ %>

            <li>
              <a class="dropdown-item fw-semibold" href="/login">
                Log in
              </a>
            </li>

            <li>
              <a class="dropdown-item" href="/signup">
                Sign up
              </a>
            </li>

          <% } %>


          <!-- ========= USER LOGGED IN ========= -->

          <% if(currUser){ %>

            <li>
              <a class="dropdown-item fw-semibold" href="/profile">
                Profile
              </a>
            </li>

            <li>
              <a class="dropdown-item" href="/listings/new">
                Add Listing
              </a>
            </li>

            <li>
              <hr class="dropdown-divider">
            </li>

            <li>
              <a class="dropdown-item text-danger" href="/logout">
                Logout
              </a>
            </li>

          <% } %>


        </ul>

      </div>


    </div>
  </div>
</nav>